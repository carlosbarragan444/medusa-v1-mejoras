# Database
DATABASE_URL=postgresql://user:password@localhost:5432/medusa_db
REDIS_URL=redis://localhost:6379

# Secrets (generate with: openssl rand -base64 48)
JWT_SECRET=your-jwt-secret-here-change-this
COOKIE_SECRET=your-cookie-secret-here-change-this

# Admin credentials
MEDUSA_ADMIN_EMAIL=admin@kingkeys.com
MEDUSA_ADMIN_PASSWORD=admin123456

# CORS settings
STORE_CORS=http://localhost:8000,http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:3000

# Medusa configuration
MEDUSA_WORKER_MODE=shared
MEDUSA_DISABLE_ADMIN=false
NODE_ENV=development

# Storage (MinIO - optional)
FILE_PROVIDER=local

# Stripe (optional)
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# SendGrid (optional)
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM=noreply@kingkeys.com
